DATABASE_URL=postgres://dev:dev@localhost:5432/checkout
JWT_SECRET=change-me-min-32-chars-random-string
AUTH_PROVIDER=jwt                   # jwt | mock | supabase
DB_PROVIDER=postgres
DB_SSL=false
SHELL_ORIGIN=http://localhost:3000
PORT=4000

# Supabase auth — required when AUTH_PROVIDER=supabase
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>
# SUPABASE_JWT_SECRET=<jwt-secret-from-supabase-dashboard>

# Pricing rules — omit to use defaults (13% tax, 10% discount over $100)
# PRICING_TAX_RATE=0.13
# PRICING_DISCOUNT_THRESHOLD=100
# PRICING_DISCOUNT_RATE=0.10
